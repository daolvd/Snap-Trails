# Xcode
#
# gitignore contributors: remember to update Global/Xcode.gitignore, Objective-C.gitignore & Swift.gitignore

## User-specific
xcuserdata/

## Root-level (generated by Xcode)
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

## Xcode 4 and later
DerivedData/
*.xccheckout
*.xcuserstate
*.xcscmblueprint
*.screenshot
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.xcworkspace/xcshareddata/SwiftPM/configuration/Package.resolved
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.xcodeproj/project.xcworkspace/xcshareddata/SwiftPM/configuration/Package.resolved
*.xcodeproj/xcuserdata/

## Xcode 16 and later
.xcresult/

## Xcode Cloud
ci_scripts/BuildProducts/

## Swift Package Manager
.build/
.swiftpm/
Package.resolved

## AppCode
.idea/

## Localization
*.swp
*.lock
*~.nib

## macOS
.DS_Store

## Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output

## CocoaPods
Pods/
*.xcworkspace

## Carthage
Carthage/Build/
Carthage/Checkouts/

## Design assets
# Ignore the design folder as it contains exported assets and reference material
design/
